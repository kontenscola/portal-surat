# Supabase — dapatkan dari https://supabase.com/dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — RAHASIA, jangan expose ke browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret untuk sesi siswa — gunakan string acak yang panjang dan aman
# Contoh generate: openssl rand -base64 32
JWT_SECRET=your-random-secret-key-here
